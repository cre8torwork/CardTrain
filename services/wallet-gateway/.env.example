# Card Train wallet gateway — environment. Real values are set as deploy-platform
# secrets (Railway/Fly), NEVER committed.

# Shared secret the Supabase edge functions present as X-Service-Key.
WALLET_SERVICE_KEY=change-me-long-random

# test | production  (selects the ics2ws endpoint + WSDL host)
CYBS_ENV=test
CYBS_API_VERSION=1.219

# Google Pay MID …201
CYBS_GOOGLE_MERCHANT_ID=gphk088034609201
CYBS_GOOGLE_P12_BASE64=            # base64 of the .p12 for this MID
CYBS_GOOGLE_KEY_PASS=              # P12 password (defaults to the merchant id)

# Apple Pay MID …202
CYBS_APPLE_MERCHANT_ID=gphk088034609202
CYBS_APPLE_P12_BASE64=             # base64 of the .p12 for this MID
CYBS_APPLE_KEY_PASS=

# Injected by the host; local default 8080
# PORT=8080
